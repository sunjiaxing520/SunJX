DATABASE_URL=postgresql://blue_music:blue_music_pass@localhost:5432/blue_music_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace_with_at_least_32_random_characters
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
APP_TIMEZONE=Asia/Shanghai
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_TO_FILE=true
LOG_DIR=
LOG_RETENTION_DAYS=30
RANKING_RETENTION_DAYS=30
RANKING_DEFAULT_LIMIT=100
KUGOU_REQUEST_TIMEOUT_SECONDS=15
KUGOU_MAX_RETRIES=3
# local keeps development and tests free. Use openai_compatible after choosing a text model.
AI_PROVIDER=local
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# Stable key used to encrypt database-stored provider credentials. Never rotate it casually.
AI_CONFIG_ENCRYPTION_KEY=replace_with_another_stable_random_secret
AI_REQUEST_TIMEOUT_SECONDS=180
AI_MAX_RETRIES=2
# Suno official Platform credentials. Keep blank until API access is granted.
SUNO_API_BASE_URL=
SUNO_API_KEY=
SUNO_MODEL=
SUNO_REQUEST_TIMEOUT_SECONDS=120
SUNO_GENERATION_TIMEOUT_SECONDS=900
SUNO_POLL_INTERVAL_SECONDS=10
SUNO_DOWNLOAD_TIMEOUT_SECONDS=120
SUNO_MAX_AUDIO_BYTES=104857600
MUSIC_STORAGE_DIR=
# Leave a short gap between text AI steps to reduce free-tier rate limiting.
WORKFLOW_STEP_DELAY_SECONDS=15
WORKFLOW_STALE_SECONDS=1800
INITIAL_SUPERADMIN_USERNAME=admin
# Set INITIAL_SUPERADMIN_PASSWORD only for one-time automated deployment.
